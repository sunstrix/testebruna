# =============================================================================
# ESSENCIA RH - VARIÁVEIS DE AMBIENTE
# CP FANI | Sistema de Gestão de Departamento Pessoal
# =============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env: cp .env.example .env
# 2. Preencha os valores reais das variáveis
# 3. NUNCA commite o arquivo .env no repositório
# 4. O arquivo .env está no .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SEGURANÇA DA APLICAÇÃO (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
# Chave secreta do Flask para sessões e CSRF
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_muito_forte_aqui_mude_isso

# -----------------------------------------------------------------------------
# GOOGLE SHEETS API (OBRIGATÓRIO - Persistência de Dados)
# -----------------------------------------------------------------------------
# ID da planilha Google Sheets (obtido via init_sheets.py ou URL da planilha)
# Exemplo: https://docs.google.com/spreadsheets/d/ESTE_E_O_ID/edit
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Credenciais da Service Account (DUAS OPÇÕES - escolha UMA):

# OPÇÃO 1: JSON em base64 (recomendado para deploy cloud - Render/Railway)
# Gere com: cat credentials.json | base64 -w 0
GOOGLE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsICJwcm9qZWN0X2lkIjog...

# OPÇÃO 2: Caminho do arquivo JSON (recomendado para desenvolvimento local)
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# -----------------------------------------------------------------------------
# INTEGRAÇÃO TELEGRAM (OPCIONAL - Alertas Automáticos)
# -----------------------------------------------------------------------------
# Token do Bot do Telegram (obtido via @BotFather)
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID do Chat/Grupo para receber alertas
# TELEGRAM_CHAT_ID=-1001234567890

# -----------------------------------------------------------------------------
# INTEGRAÇÃO GMAIL SMTP (OPCIONAL - Envio de E-mails)
# -----------------------------------------------------------------------------
# E-mail do Gmail (conta comum ou Google Workspace)
# EMAIL_USER=rh@cpfani.com.br

# Senha de aplicativo do Gmail (NÃO é a senha normal da conta)
# Gere em: https://myaccount.google.com/apppasswords
# EMAIL_PASS=abcd_efgh_ijkl_mnop

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# -----------------------------------------------------------------------------
# Ambiente de execução (development ou production)
FLASK_ENV=development

# Título da planilha (usado apenas na primeira execução do init_sheets.py)
SPREADSHEET_TITLE=Essencia_RH_Database

# E-mail para compartilhar a planilha automaticamente (opcional)
# ADMIN_EMAIL_TO_SHARE=admin@cpfani.com.br

# -----------------------------------------------------------------------------
# BACKUP GOOGLE DRIVE (OPCIONAL)
# -----------------------------------------------------------------------------
# Habilitar backup automático da planilha no Google Drive
# Usa as mesmas credenciais do Google Sheets
# ENABLE_DRIVE_BACKUP=false

# -----------------------------------------------------------------------------
# LOGS E DEBUG
# -----------------------------------------------------------------------------
# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Habilitar logs detalhados do Google Sheets API
# GOOGLE_API_DEBUG=false